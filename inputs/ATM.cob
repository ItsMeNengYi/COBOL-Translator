IDENTIFICATION DIVISION.
PROGRAM-ID. ATM-MACHINE.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT USERDATA ASSIGN TO "atm_accounts.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS RANDOM
        RECORD KEY IS F-ACCOUNT
        FILE STATUS IS WS-FILE-STATUS.

DATA DIVISION.
FILE SECTION.
FD USERDATA.

01 F-DATA.
    02 F-ACCOUNT  PIC 9(10).
    02 F-PIN      PIC 9(6).
    02 F-BAL      PIC 9(12).
    02 F-NAME     PIC X(20).
    02 F-AGE      PIC 99.

WORKING-STORAGE SECTION.
01 WS-FILE-STATUS PIC XX.
01 WS-MAIN-CHOICE PIC 99 VALUE 0.
01 WS-CHOICE      PIC 99 VALUE 0.
01 WS-ACCOUNT     PIC 9(10) VALUE 0.
01 WS-PIN         PIC 9(6) VALUE 0.
01 WS-AMOUNT      PIC 9(12) VALUE 0.
01 WS-FOUND       PIC X VALUE "N".

PROCEDURE DIVISION.

MAIN-PROCEDURE.

    OPEN I-O USERDATA

    IF WS-FILE-STATUS = "35"
        OPEN OUTPUT USERDATA
        CLOSE USERDATA
        OPEN I-O USERDATA
    END-IF

    PERFORM UNTIL WS-MAIN-CHOICE = 3
        MOVE 0 TO WS-MAIN-CHOICE

        DISPLAY " "
        DISPLAY "===== ATM SYSTEM ====="
        DISPLAY "1 - CREATE ACCOUNT"
        DISPLAY "2 - LOGIN"
        DISPLAY "3 - EXIT"

        PERFORM UNTIL WS-MAIN-CHOICE >= 1
                  AND WS-MAIN-CHOICE <= 3
            DISPLAY "ENTER CHOICE:"
            ACCEPT WS-MAIN-CHOICE

            IF WS-MAIN-CHOICE < 1
               OR WS-MAIN-CHOICE > 3
                DISPLAY "INVALID CHOICE"
                DISPLAY "PLEASE ENTER 1, 2, OR 3"
            END-IF
        END-PERFORM

        EVALUATE WS-MAIN-CHOICE
            WHEN 1
                PERFORM CREATE-ACCOUNT
            WHEN 2
                PERFORM LOGIN
            WHEN 3
                DISPLAY "GOODBYE"
        END-EVALUATE
    END-PERFORM

    CLOSE USERDATA
    STOP RUN.

CREATE-ACCOUNT.
    MOVE SPACES TO F-NAME
    MOVE 0 TO F-AGE
    MOVE 0 TO F-PIN

    DISPLAY "ENTER NAME:"
    ACCEPT F-NAME

    IF F-NAME = SPACES
        DISPLAY "NAME CANNOT BE EMPTY"
        EXIT PARAGRAPH
    END-IF

    DISPLAY "ENTER AGE:"
    ACCEPT F-AGE

    IF F-AGE < 18
        DISPLAY "YOU MUST BE AT LEAST 18 YEARS OLD"
        EXIT PARAGRAPH
    END-IF

    PERFORM UNTIL F-PIN >= 100000
        DISPLAY "CREATE 6-DIGIT PIN:"
        ACCEPT F-PIN

        IF F-PIN < 100000
            DISPLAY "PIN MUST BE 6 DIGITS"
        END-IF
    END-PERFORM

    PERFORM GENERATE-ACCOUNT

    MOVE 0 TO F-BAL

    WRITE F-DATA
        INVALID KEY
            DISPLAY "ACCOUNT CREATION FAILED"
        NOT INVALID KEY
            DISPLAY "ACCOUNT CREATED SUCCESSFULLY"
            DISPLAY "YOUR ACCOUNT NUMBER IS:"
            DISPLAY F-ACCOUNT
    END-WRITE

    EXIT.

GENERATE-ACCOUNT.
    COMPUTE F-ACCOUNT =
        FUNCTION RANDOM * 8999999999 + 1000000000

    READ USERDATA
        INVALID KEY
            CONTINUE
        NOT INVALID KEY
            PERFORM GENERATE-ACCOUNT
    END-READ

    EXIT.

LOGIN.
    MOVE "N" TO WS-FOUND
    MOVE 0 TO WS-ACCOUNT
    MOVE 0 TO WS-PIN

    PERFORM UNTIL WS-ACCOUNT > 0
        DISPLAY "ENTER ACCOUNT NUMBER:"
        ACCEPT WS-ACCOUNT

        IF WS-ACCOUNT <= 0
            DISPLAY "INVALID ACCOUNT NUMBER"
        END-IF
    END-PERFORM

    MOVE WS-ACCOUNT TO F-ACCOUNT

    READ USERDATA
        INVALID KEY
            MOVE "N" TO WS-FOUND
        NOT INVALID KEY
            MOVE "Y" TO WS-FOUND
    END-READ

    IF WS-FOUND = "N"
        DISPLAY "ACCOUNT NOT FOUND"
    ELSE
        PERFORM UNTIL WS-PIN >= 100000
            DISPLAY "ENTER PIN:"
            ACCEPT WS-PIN

            IF WS-PIN < 100000
                DISPLAY "PIN MUST BE 6 DIGITS"
            END-IF
        END-PERFORM

        IF WS-PIN = F-PIN
            DISPLAY "LOGIN SUCCESSFUL"
            DISPLAY "WELCOME, " F-NAME
            MOVE 0 TO WS-CHOICE
            PERFORM ATM-MENU UNTIL WS-CHOICE = 4
        ELSE
            DISPLAY "WRONG PIN"
            DISPLAY "PLEASE TRY AGAIN"
        END-IF
    END-IF

    EXIT.

ATM-MENU.
    MOVE 0 TO WS-CHOICE

    DISPLAY " "
    DISPLAY "===== ATM MENU ====="
    DISPLAY "ACCOUNT: " F-ACCOUNT
    DISPLAY "NAME: " F-NAME
    DISPLAY "1 - CHECK BALANCE"
    DISPLAY "2 - DEPOSIT"
    DISPLAY "3 - WITHDRAW"
    DISPLAY "4 - LOGOUT"

    PERFORM UNTIL WS-CHOICE >= 1
              AND WS-CHOICE <= 4
        DISPLAY "ENTER CHOICE:"
        ACCEPT WS-CHOICE

        IF WS-CHOICE < 1
           OR WS-CHOICE > 4
            DISPLAY "INVALID CHOICE"
            DISPLAY "PLEASE ENTER 1, 2, 3, OR 4"
        END-IF
    END-PERFORM

    EVALUATE WS-CHOICE
        WHEN 1
            PERFORM CHECK-BALANCE
        WHEN 2
            PERFORM DEPOSIT
        WHEN 3
            PERFORM WITHDRAW
        WHEN 4
            DISPLAY "LOGGING OUT"
    END-EVALUATE

    EXIT.

CHECK-BALANCE.
    DISPLAY "CURRENT BALANCE:"
    DISPLAY F-BAL
    EXIT.

DEPOSIT.
    MOVE 0 TO WS-AMOUNT

    PERFORM UNTIL WS-AMOUNT > 0
        DISPLAY "ENTER DEPOSIT AMOUNT:"
        ACCEPT WS-AMOUNT

        IF WS-AMOUNT <= 0
            DISPLAY "INVALID AMOUNT"
            DISPLAY "AMOUNT MUST BE POSITIVE"
        END-IF
    END-PERFORM

    ADD WS-AMOUNT TO F-BAL

    REWRITE F-DATA
        INVALID KEY
            DISPLAY "UPDATE FAILED"
        NOT INVALID KEY
            DISPLAY "DEPOSIT SUCCESSFUL"
            DISPLAY "NEW BALANCE:"
            DISPLAY F-BAL
    END-REWRITE

    EXIT.

WITHDRAW.
    MOVE 0 TO WS-AMOUNT

    PERFORM UNTIL WS-AMOUNT > 0
        DISPLAY "ENTER WITHDRAW AMOUNT:"
        ACCEPT WS-AMOUNT

        IF WS-AMOUNT <= 0
            DISPLAY "INVALID AMOUNT"
            DISPLAY "AMOUNT MUST BE POSITIVE"
        END-IF
    END-PERFORM

    IF WS-AMOUNT > F-BAL
        DISPLAY "INSUFFICIENT BALANCE"
    ELSE
        SUBTRACT WS-AMOUNT FROM F-BAL

        REWRITE F-DATA
            INVALID KEY
                DISPLAY "UPDATE FAILED"
            NOT INVALID KEY
                DISPLAY "WITHDRAW SUCCESSFUL"
                DISPLAY "NEW BALANCE:"
                DISPLAY F-BAL
        END-REWRITE
    END-IF

    EXIT.

END PROGRAM ATM-MACHINE.
